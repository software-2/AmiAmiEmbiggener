{
    "manifest_version": 3,
    "name": "AmiAmi Embiggener",
    "version": "1.2",
    "description": "Adds several quality of life enhancements to browsing AmiAmi.",
    "homepage_url": "https://github.com/software-2/AmiAmiEmbiggener",
    "host_permissions": ["https://*.amiami.com/*"],
    "content_scripts": [
      {
        "matches": ["https://*.amiami.com/*"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "amiami-embiggener@example.com",
        "strict_min_version": "100.0"
      }
    }
  }